{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AstrBot-RSS Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "feeds": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "url"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "Feed 唯一 ID"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "RSS/Atom 源地址"
          },
          "auth_mode": {
            "type": "string",
            "enum": [
              "none",
              "query",
              "header"
            ],
            "default": "none",
            "description": "鉴权模式"
          },
          "key": {
            "type": "string",
            "default": "",
            "description": "query/header 使用的鉴权密钥"
          },
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "timeout": {
            "type": "integer",
            "minimum": 1,
            "default": 10,
            "description": "请求超时时间（秒）"
          }
        }
      }
    },
    "targets": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "platform"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "目标唯一 ID"
          },
          "platform": {
            "type": "string",
            "minLength": 1,
            "description": "平台标识，如 qq/telegram"
          },
          "unified_msg_origin": {
            "type": "string",
            "default": "",
            "description": "AstrBot 统一会话标识；也可使用平台特有会话字段"
          },
          "enabled": {
            "type": "boolean",
            "default": true
          }
        },
        "anyOf": [
          {
            "required": [
              "unified_msg_origin"
            ]
          },
          {
            "required": [
              "session_id"
            ]
          },
          {
            "required": [
              "chat_id"
            ]
          }
        ]
      }
    },
    "jobs": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "feed_ids",
          "target_ids"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "任务唯一 ID"
          },
          "feed_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "target_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "cron": {
            "type": "string",
            "default": "",
            "description": "cron 表达式，和 interval_seconds 至少其一"
          },
          "interval_seconds": {
            "type": "integer",
            "minimum": 1,
            "description": "轮询间隔秒数，和 cron 至少其一"
          },
          "batch_size": {
            "type": "integer",
            "minimum": 1,
            "default": 10
          },
          "enabled": {
            "type": "boolean",
            "default": true
          }
        },
        "anyOf": [
          {
            "required": [
              "cron"
            ]
          },
          {
            "required": [
              "interval_seconds"
            ]
          }
        ]
      }
    }
  }
}
