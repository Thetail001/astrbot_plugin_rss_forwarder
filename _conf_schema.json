{
  "feeds": {
    "type": "template_list",
    "description": "RSS 源配置",
    "templates": {
      "feed": {
        "name": "RSS 源",
        "hint": "配置一个 RSS/Atom 源",
        "items": {
          "id": {
            "type": "string",
            "default": "",
            "description": "Feed 唯一 ID"
          },
          "url": {
            "type": "string",
            "default": "",
            "description": "RSS/Atom 源地址"
          },
          "auth_mode": {
            "type": "string",
            "default": "none",
            "options": [
              "none",
              "query",
              "header"
            ],
            "description": "鉴权模式"
          },
          "key": {
            "type": "string",
            "default": "",
            "description": "query/header 使用的鉴权密钥"
          },
          "enabled": {
            "type": "bool",
            "default": false,
            "description": "是否启用该源",
            "hint": "新建条目默认关闭，补全 Feed ID 与地址后再启用。"
          },
          "timeout": {
            "type": "int",
            "default": 10,
            "description": "抓取请求超时时间（秒）"
          }
        }
      }
    }
  },
  "targets": {
    "type": "template_list",
    "description": "推送目标配置",
    "templates": {
      "target": {
        "name": "推送目标",
        "hint": "配置一个消息推送目标",
        "items": {
          "id": {
            "type": "string",
            "default": "",
            "description": "目标唯一 ID"
          },
          "platform": {
            "type": "string",
            "default": "",
            "description": "平台标识，如 qq/telegram"
          },
          "unified_msg_origin": {
            "type": "string",
            "default": "",
            "description": "AstrBot 统一会话标识",
            "hint": "启用该目标时必须填写，可先保存为草稿，补全后再启用。"
          },
          "enabled": {
            "type": "bool",
            "default": false,
            "description": "是否启用该目标",
            "hint": "新建条目默认关闭，补全平台与会话标识后再启用。"
          }
        }
      }
    }
  },
  "jobs": {
    "type": "template_list",
    "description": "任务配置",
    "templates": {
      "job": {
        "name": "轮询任务",
        "hint": "一个任务可绑定多个 feed 与多个 target",
        "items": {
          "id": {
            "type": "string",
            "default": "",
            "description": "任务唯一 ID"
          },
          "feed_ids": {
            "type": "list",
            "default": [],
            "description": "关联的 feed ID 列表"
          },
          "target_ids": {
            "type": "list",
            "default": [],
            "description": "关联的 target ID 列表"
          },
          "cron": {
            "type": "string",
            "default": "",
            "description": "cron 表达式（当前版本可留空）"
          },
          "interval_seconds": {
            "type": "int",
            "default": 300,
            "description": "轮询间隔秒数"
          },
          "batch_size": {
            "type": "int",
            "default": 10,
            "description": "每次推送最大条数"
          },
          "enabled": {
            "type": "bool",
            "default": false,
            "description": "是否启用该任务",
            "hint": "新建条目默认关闭，补全 feed 与 target 关联后再启用。"
          }
        }
      }
    }
  },
  "daily_digests": {
    "type": "template_list",
    "description": "日报任务配置",
    "templates": {
      "daily_digest": {
        "name": "日报任务",
        "hint": "独立于即时推送的聚合日报，可复用现有 feed 与 target",
        "items": {
          "id": {
            "type": "string",
            "default": "",
            "description": "日报任务唯一 ID"
          },
          "title": {
            "type": "string",
            "default": "",
            "description": "日报标题",
            "hint": "留空时将使用日报任务 ID。"
          },
          "feed_ids": {
            "type": "list",
            "default": [],
            "description": "参与汇总的 feed ID 列表"
          },
          "target_ids": {
            "type": "list",
            "default": [],
            "description": "发送日报的 target ID 列表"
          },
          "send_time": {
            "type": "string",
            "default": "09:00",
            "description": "每日发送时间",
            "hint": "格式为 HH:MM，按 AstrBot 当前时区解释。"
          },
          "window_hours": {
            "type": "int",
            "default": 24,
            "description": "滚动统计时长（小时）"
          },
          "max_items": {
            "type": "int",
            "default": 20,
            "description": "日报最大条目数"
          },
          "render_mode": {
            "type": "string",
            "default": "text",
            "options": [
              "text",
              "image"
            ],
            "description": "日报渲染模式：text(文本列表) / image(图卡)"
          },
          "prompt_template": {
            "type": "string",
            "default": "请根据以下 RSS 条目生成一份简体中文日报，严格输出纯文本编号列表。\n要求：\n1) 只输出编号列表，不要导语、总结、分类标题或 Markdown 代码块；\n2) 最多输出 {max_items} 条；\n3) 每条一句话，优先保留来源信息；\n4) 如果多条内容高度相近，可合并为一条更准确的概述。\n\n统计窗口：{window_start} 至 {window_end}\n条目：\n{items}",
            "description": "日报提示词模板",
            "hint": "可用变量：title/window_start/window_end/max_items/items。仅在存在可用 LLM 时生效。"
          },
          "enabled": {
            "type": "bool",
            "default": false,
            "description": "是否启用该日报任务",
            "hint": "可先保存为草稿，补全 feed、target 与发送时间后再启用。"
          }
        }
      }
    }
  },
  "translation": {
    "type": "object",
    "description": "翻译增强（LLM / Google / GitHub Models）",
    "hint": "顺序：LLM -> Google -> GitHub Models。前一层失败后，将自动尝试下一层。",
    "items": {
      "llm_enabled": {
        "type": "bool",
        "default": false,
        "description": "启用 LLM 摘要/翻译"
      },
      "llm_provider_id": {
        "type": "string",
        "default": "",
        "_special": "select_provider",
        "description": "LLM 提供商 ID",
        "hint": "留空自动使用当前会话/默认模型；可点击右侧按钮下拉选择。"
      },
      "llm_timeout_seconds": {
        "type": "int",
        "default": 15,
        "description": "LLM 超时（秒）",
        "hint": "超时后将继续尝试后续翻译服务。"
      },
      "llm_profile": {
        "type": "string",
        "default": "rss_enrich",
        "description": "LLM profile（高级）",
        "hint": "一般保持默认即可。"
      },
      "max_input_chars": {
        "type": "int",
        "default": 2000,
        "description": "发送给翻译器的最大输入字符数"
      },
      "llm_proxy_mode": {
        "type": "string",
        "default": "system",
        "options": [
          "off",
          "system",
          "custom"
        ],
        "description": "LLM 代理模式（尽力）",
        "hint": "off=不走代理，system=使用系统代理，custom=使用下方代理地址。是否生效取决于所选 Provider。"
      },
      "llm_proxy_url": {
        "type": "string",
        "default": "",
        "description": "LLM 自定义代理地址（尽力）",
        "hint": "示例：http://127.0.0.1:7890（仅 custom 生效，是否生效取决于 Provider）"
      },
      "google_translate_enabled": {
        "type": "bool",
        "default": false,
        "description": "启用 Google 翻译第一后备"
      },
      "google_translate_api_key": {
        "type": "string",
        "default": "",
        "description": "Google Cloud Translation API Key",
        "obvious_hint": true,
        "hint": "在 Google Cloud Console 中启用 Cloud Translation Basic v2 后创建 API Key。"
      },
      "google_translate_target_lang": {
        "type": "string",
        "default": "zh-CN",
        "description": "Google 翻译目标语言",
        "hint": "例如 zh-CN / ja / en"
      },
      "google_translate_timeout_seconds": {
        "type": "int",
        "default": 15,
        "description": "Google 翻译超时（秒）"
      },
      "google_translate_proxy_mode": {
        "type": "string",
        "default": "system",
        "options": [
          "off",
          "system",
          "custom"
        ],
        "description": "Google 翻译代理模式",
        "hint": "off=不走代理，system=使用系统代理，custom=使用下方代理地址"
      },
      "google_translate_proxy_url": {
        "type": "string",
        "default": "",
        "description": "Google 翻译自定义代理地址",
        "hint": "示例：http://127.0.0.1:7890（仅 custom 生效）"
      },
      "github_models_enabled": {
        "type": "bool",
        "default": false,
        "description": "启用 GitHub Models 第二后备"
      },
      "github_models_model": {
        "type": "string",
        "default": "openai/gpt-4o-mini",
        "description": "GitHub Models 模型 ID",
        "hint": "示例：openai/gpt-4o-mini"
      },
      "github_models_timeout_seconds": {
        "type": "int",
        "default": 15,
        "description": "GitHub Models 超时（秒）"
      },
      "github_models_token_file": {
        "type": "string",
        "default": "github.token",
        "description": "GitHub token 文件路径",
        "hint": "相对路径按 AstrBot data 目录解析，例如 github.token -> data/github.token"
      },
      "github_models_proxy_mode": {
        "type": "string",
        "default": "system",
        "options": [
          "off",
          "system",
          "custom"
        ],
        "description": "GitHub Models 代理模式",
        "hint": "off=不走代理，system=使用系统代理，custom=使用下方代理地址"
      },
      "github_models_proxy_url": {
        "type": "string",
        "default": "",
        "description": "GitHub Models 自定义代理地址",
        "hint": "示例：http://127.0.0.1:7890（仅 custom 生效）"
      }
    }
  },
  "startup_delay_seconds": {
    "type": "int",
    "default": 45,
    "description": "插件启动后的首次轮询延迟（秒），默认 45 秒"
  },
  "render_mode": {
    "type": "string",
    "default": "text",
    "options": [
      "text",
      "image"
    ],
    "description": "消息渲染模式：text(纯文本+链接) / image(图文卡片)"
  },
  "summary_max_chars": {
    "type": "int",
    "default": 280,
    "description": "摘要最大长度，超出后会截断并附带“查看全文”链接"
  },
  "render_card_template": {
    "type": "object",
    "default": {},
    "description": "图卡/文本渲染模板字段",
    "items": {
      "title": {
        "type": "string",
        "default": "{title}",
        "description": "标题模板，可用变量：title/source/published_at/summary/link"
      },
      "source": {
        "type": "string",
        "default": "{source}",
        "description": "来源模板"
      },
      "published_at": {
        "type": "string",
        "default": "{published_at}",
        "description": "时间模板"
      },
      "summary": {
        "type": "string",
        "default": "{summary}",
        "description": "摘要模板"
      },
      "link_text": {
        "type": "string",
        "default": "查看全文",
        "description": "链接文本模板"
      }
    }
  }
}
